# Variáveis usadas pelo docker-compose.
# Copie para ".env" e ajuste se necessário. Há defaults para subir sem editar.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cadastro

# Porta do Postgres publicada no host (para clientes externos como o Beekeeper).
POSTGRES_PORT=5432

# Porta em que o front (nginx) fica exposto no host.
WEB_PORT=8080

# Origem liberada no CORS da API (o front acessa a API pelo proxy do nginx,
# então em produção normalmente não é necessário alterar).
CORS_ORIGIN=http://localhost:8080
